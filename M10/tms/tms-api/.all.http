@baseUrl = http://localhost:3000
@customersUrl = {{baseUrl}}/customers

# Set this to an existing customer before running detail/delete requests.
@customerId = 1
@missingCustomerId = 999999

@page = 1
@limit = 10
@search = john

###
# Status
###

### Server status (plain text)
GET {{baseUrl}}/

### Health check
GET {{baseUrl}}/health

###
# Customers
###

### List customers
GET {{customersUrl}}?page={{page}}&limit={{limit}}

### List customers with search
GET {{customersUrl}}?page={{page}}&limit={{limit}}&search={{search}}

### Get customer details
GET {{customersUrl}}/{{customerId}}

### Get missing customer details
GET {{customersUrl}}/{{missingCustomerId}}

### Update customer first name
PATCH {{customersUrl}}/{{customerId}}
Content-Type: application/json

{
  "version": 3,
  "first_name": "Krzyś"
}

### Update customer last name
PATCH {{customersUrl}}/{{customerId}}
Content-Type: application/json

{
  "version": 1,
  "last_name": "Nowak"
}

### Update customer first and last name
PATCH {{customersUrl}}/{{customerId}}
Content-Type: application/json

{
  "version": 1,
  "first_name": "UpdatedName",
  "last_name": "UpdatedLastName"
}

### Patch missing customer – should return 404
PATCH {{customersUrl}}/{{missingCustomerId}}
Content-Type: application/json

{
  "version": 1,
  "first_name": "Ghost"
}

### Patch customer without body fields – should return 400
PATCH {{customersUrl}}/{{customerId}}
Content-Type: application/json

{}

### Patch customer with stale version – should return 409
PATCH {{customersUrl}}/{{customerId}}
Content-Type: application/json

{
  "version": 0,
  "first_name": "Konflikt"
}

### Delete customer
DELETE {{customersUrl}}/{{customerId}}

### Delete missing customer
DELETE {{customersUrl}}/{{missingCustomerId}}


###
# Drivers
###

@driversUrl = {{baseUrl}}/drivers
@driverId = 1
@missingDriverId = 999999

### List all drivers
GET {{driversUrl}}

### Get driver details (with licenses)
GET {{driversUrl}}/{{driverId}}

### Get missing driver – should return 404
GET {{driversUrl}}/{{missingDriverId}}

### Create driver
POST {{driversUrl}}
Content-Type: application/json

{
  "first_name": "Jan",
  "last_name": "Kowalski",
  "email": "jan.kowalski@example.com",
  "phone": "+48123456789",
  "contract_type": "full_time",
  "status": "active"
}

### Delete missing driver – should return 404
DELETE {{driversUrl}}/{{missingDriverId}}

###
# Transportation Orders
###

@ordersUrl = {{baseUrl}}/transportation-orders
@orderCustomerId = 1

### List all transportation orders
GET {{ordersUrl}}

### List transportation orders for a specific customer
GET {{ordersUrl}}?customer_id={{orderCustomerId}}


###
# Notifications
###

@notificationsUrl = {{baseUrl}}/notifications
@notificationUserId = 1

### List notifications for a user
GET {{notificationsUrl}}?userId={{notificationUserId}}

### List notifications for a user – page 2
GET {{notificationsUrl}}?userId={{notificationUserId}}&page=2&limit=5

### Missing userId – should return 400
GET {{notificationsUrl}}

### Invalid userId – should return 400
GET {{notificationsUrl}}?userId=abc


###
# Vehicles
###

@vehiclesUrl = {{baseUrl}}/vehicles
@vehicleId = 1
@missingVehicleId = 999999

### List all vehicles
GET {{vehiclesUrl}}

### Get vehicle details
GET {{vehiclesUrl}}/{{vehicleId}}

### Get missing vehicle – should return 404
GET {{vehiclesUrl}}/{{missingVehicleId}}

### Create vehicle
POST {{vehiclesUrl}}
Content-Type: application/json

{
  "make": "Volvo",
  "model": "FH16",
  "year": 2022,
  "fuel_tank_capacity": 750
}

### Update vehicle
PUT {{vehiclesUrl}}/{{vehicleId}}
Content-Type: application/json

{
  "make": "Scania",
  "model": "R500",
  "year": 2023,
  "fuel_tank_capacity": 800
}

### Update missing vehicle – should return 404
PUT {{vehiclesUrl}}/{{missingVehicleId}}
Content-Type: application/json

{
  "make": "Scania",
  "model": "R500",
  "year": 2023,
  "fuel_tank_capacity": 800
}

### Delete vehicle
DELETE {{vehiclesUrl}}/{{vehicleId}}

### Delete missing vehicle – should return 404
DELETE {{vehiclesUrl}}/{{missingVehicleId}}


###
# Cargo Plans
###

@cargoPlansUrl = {{baseUrl}}/cargo-plans

### Create a new load plan (standard curtainside)
POST {{cargoPlansUrl}}
Content-Type: application/json

{
  "trailerType": "standard-curtainside"
}

### Create a new load plan (reefer)
POST {{cargoPlansUrl}}
Content-Type: application/json

{
  "trailerType": "reefer"
}

### Get load plan by ID (paste a real ID from create response)
@planId = PASTE_PLAN_ID_HERE
GET {{cargoPlansUrl}}/{{planId}}

### Add cargo – EPAL1 pallet with food
POST {{cargoPlansUrl}}/{{planId}}/cargo
Content-Type: application/json

{
  "palletType": "epal1",
  "cargoType": "FOOD",
  "requirements": {
    "isTemperatureControlled": true,
    "requiresSideLoading": false,
    "isBulk": false,
    "highSecurityRequired": false
  },
  "weightKg": 500,
  "cargoHeightMm": 1500
}

### Add cargo – industrial pallet with electronics
POST {{cargoPlansUrl}}/{{planId}}/cargo
Content-Type: application/json

{
  "palletType": "industrial",
  "cargoType": "ELECTRONICS",
  "requirements": {
    "isTemperatureControlled": false,
    "requiresSideLoading": false,
    "isBulk": false,
    "highSecurityRequired": false
  },
  "weightKg": 800,
  "cargoHeightMm": 1200
}

### Remove cargo unit from plan (paste a real unitId from GET response)
@unitId = PASTE_UNIT_ID_HERE
DELETE {{cargoPlansUrl}}/{{planId}}/cargo/{{unitId}}

### Change trailer type to mega
PUT {{cargoPlansUrl}}/{{planId}}/trailer
Content-Type: application/json

{
  "trailerType": "mega"
}

### Finalize load plan
POST {{cargoPlansUrl}}/{{planId}}/finalize

### Get non-existing plan – should return 404
GET {{cargoPlansUrl}}/non-existing-id

### Add cargo with invalid body – should return 400
POST {{cargoPlansUrl}}/{{planId}}/cargo
Content-Type: application/json

{
  "palletType": "epal1"
}
