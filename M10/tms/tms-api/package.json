{
  "name": "tms-api",
  "author": "Developer Jutra",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "generate:types:swagger-typescript-api": "node scripts/generate-api-types.js",
    "generate:types:openapi-typescript": "openapi-typescript contract/openapi.yaml --output contract/contract-types-openapi-typescript/contract.ts",
    "generate:types:openapi-zod-client": "openapi-zod-client contract/openapi.yaml -o contract/contract-types-openapi-zod-client/contract.ts --export-schemas -t contract/template.hbs",
    "generate:types:orval": "orval",
    "contract:bundle": "npx @redocly/cli bundle contract/entry.yaml -o contract/openapi.yaml",
    "contract:lint": "npx @redocly/cli lint contract/entry.yaml",
    "contract:validate": "npx @redocly/cli lint contract/openapi.yaml",
    "contract:validate:minimal": "npx @redocly/cli lint --extends minimal contract/openapi.yaml",
    "contract:serve": "nodemon --watch contract --watch src -e yaml -i contract/openapi.yaml --exec \"node scripts/serve-contract.js\"",
    "test:cucumber": "cucumber-js"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.31",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@trpc/client": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "crypto": "^1.0.1",
    "dataloader": "^2.2.3",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^4.18.2",
    "graphql": "^16.13.1",
    "graphql-http": "^1.22.4",
    "js-yaml": "^4.1.1",
    "pg": "^8.11.1",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@redocly/cli": "^2.21.0",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.13.6",
    "drizzle-kit": "^0.31.9",
    "httpyac": "^6.16.7",
    "nodemon": "^2.0.22",
    "openapi-typescript": "^7.13.0",
    "openapi-zod-client": "^1.18.3",
    "orval": "^8.5.3",
    "swagger-typescript-api": "^13.6.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3"
  }
}
