import { z } from "zod";

{{#if imports}}
{{#each imports}}
import { {{{@key}}} } from "./{{{this}}}"
{{/each}}
{{/if}}

{{#if types}}
{{#each types}}
{{{this}}};
{{/each}}
{{/if}}

{{#each schemas}}
const {{@key}}{{#if (lookup ../emittedType @key)}}: z.ZodType<{{@key}}>{{/if}} = {{{this}}};
{{/each}}

{{#ifNotEmptyObj schemas}}
export const schemas = {
{{#each schemas}}
	{{@key}},
{{/each}}
};
{{/ifNotEmptyObj}}

export const endpointParams = {
{{#each endpoints}}
  {{#if parameters}}
  {{alias}}: {
    {{#each parameters}}
    {{name}}: {{{schema}}},
    {{/each}}
  },
  {{/if}}
{{/each}}
};

export const queryParams = {
{{#each endpoints}}
  {{alias}}: z.object({
    {{#each parameters}}
    {{#ifeq type "Query"}}
    {{name}}: {{{schema}}},
    {{/ifeq}}
    {{/each}}
  }).strict(),
{{/each}}
};
